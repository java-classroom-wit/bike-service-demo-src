<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="009-add-indexes" author="student">
        <createIndex tableName="mechanic" indexName="idx_mechanic_last_name">
            <column name="last_name"/>
        </createIndex>

        <createIndex tableName="repair_order" indexName="idx_repair_order_status">
            <column name="status"/>
        </createIndex>

        <createIndex tableName="repair_order" indexName="idx_repair_order_received_at">
            <column name="received_at"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>

